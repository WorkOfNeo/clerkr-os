// Pinned to Prisma v6 вЂ” v7 removed `url`/`directUrl` from schema.prisma
// (wiki cmowr3gzo0004pr15awevff3h).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// в”Ђв”Ђв”Ђ Better-Auth-managed models в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Every id must have @default(uuid()) вЂ” Better-Auth's Prisma adapter omits
// `id` on create. The global `advanced.database.generateId: "uuid"` does NOT
// cover User (wiki cmp1usxah0004pf15nzrmtlnj). Set it on every model to be safe.

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String   @default("")
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  sessions        Session[]
  accounts        Account[]
  apiTokens       ApiToken[]
  posts           Post[]
  tasksAuthored   Task[]         @relation("TaskAuthor")
  taskAssignments TaskAssignee[]
  wikiNotes       WikiNote[]
  chatSessions    ChatSession[]
  meetings        Meeting[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

// в”Ђв”Ђв”Ђ App-owned models в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model ApiToken {
  id          String    @id @default(uuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_token")
}

model Post {
  id          String    @id @default(uuid())
  url         String
  title       String
  description String?
  imageUrl    String?
  category    String?
  todo        String?
  painPoint   String?
  priority    Int       @default(3)
  postedAt    DateTime?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([createdAt])
  @@index([priority])
  @@index([authorId])
  @@map("post")
}

// в”Ђв”Ђв”Ђ Sprint board в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Sprint metadata (testing days, planning date) is editable per-sprint; the
// "first Thursday + next-week Wed & Fri" convention lives in `src/lib/sprint-dates.ts`.

enum SprintState {
  PLANNED
  ACTIVE
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Sprint {
  id           String      @id @default(uuid())
  name         String
  slug         String      @unique
  state        SprintState @default(PLANNED)
  startDate    DateTime
  endDate      DateTime
  planningDate DateTime?
  testingDay1  DateTime?
  testingDay2  DateTime?
  testingDay3  DateTime?
  goal         String?
  retroNotes   String?
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt

  tasks        Task[]
  chatSessions ChatSession[]

  @@index([state])
  @@index([startDate])
  @@map("sprint")
}

// Taxonomy вЂ” editable lists. New rows added via the settings UI or MCP.

model TaskStatus {
  id        String   @id @default(uuid())
  label     String   @unique
  color     String
  sortOrder Int      @default(0)
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())

  tasks Task[]

  @@map("task_status")
}

model TaskGroup {
  id        String   @id @default(uuid())
  label     String   @unique
  color     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tasks Task[]

  @@map("task_group")
}

model TaskStack {
  id        String   @id @default(uuid())
  label     String   @unique
  color     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tasks Task[]

  @@map("task_stack")
}

model Task {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique
  description    String? // TipTap JSON serialized as string
  dueDate        DateTime?
  plannedDate    DateTime?
  estimatedHours Decimal?     @db.Decimal(6, 2)
  loggedHours    Decimal?     @db.Decimal(6, 2)
  priority       TaskPriority @default(MEDIUM)
  order          Int          @default(0) // sparse ordering within (sprintId, statusId)
  archivedAt     DateTime?

  statusId String
  status   TaskStatus @relation(fields: [statusId], references: [id])

  groupId String?
  group   TaskGroup? @relation(fields: [groupId], references: [id])

  stackId String?
  stack   TaskStack? @relation(fields: [stackId], references: [id])

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id])

  authorId String
  author   User   @relation("TaskAuthor", fields: [authorId], references: [id])

  // Provenance: the meeting/brief this task came from (optional).
  sourceMeetingId  String?
  sourceMeeting    Meeting?    @relation("MeetingTasks", fields: [sourceMeetingId], references: [id])
  sourceActionItem ActionItem?

  assignees TaskAssignee[]
  blockedBy TaskBlock[]    @relation("TaskBlocked")
  blocking  TaskBlock[]    @relation("TaskBlocker")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([sprintId, statusId, order])
  @@index([statusId])
  @@index([authorId])
  @@map("task")
}

model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
  @@map("task_assignee")
}

model TaskBlock {
  // "blocker" must complete before "blocked" can start.
  blockerId String
  blockedId String

  blocker Task @relation("TaskBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Task @relation("TaskBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("task_block")
}

// в”Ђв”Ђв”Ђ Wiki в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Embeddings stored as pgvector(1536) вЂ” text-embedding-3-small dimensions.
// The HNSW index is added via raw SQL in the migration (Prisma can't model
// index opclasses on Unsupported columns).

model WikiNote {
  id         String                       @id @default(uuid())
  slug       String                       @unique
  title      String
  body       String // markdown
  tags       String[]                     @default([])
  embedding  Unsupported("vector(1536)")?
  embeddedAt DateTime?
  authorId   String
  author     User                         @relation(fields: [authorId], references: [id])
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @default(now()) @updatedAt

  @@index([authorId])
  @@map("wiki_note")
}

// в”Ђв”Ђв”Ђ Chat в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatSession {
  id          String   @id @default(uuid())
  title       String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  sprintId    String?
  sprint      Sprint?  @relation(fields: [sprintId], references: [id])
  focusTaskId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  messages ChatMessage[]

  @@index([userId, updatedAt])
  @@map("chat_session")
}

model ChatMessage {
  id           String      @id @default(uuid())
  sessionId    String
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         ChatRole
  content      String
  citedNoteIds String[]    @default([])
  createdAt    DateTime    @default(now())

  @@index([sessionId, createdAt])
  @@map("chat_message")
}

// в”Ђв”Ђв”Ђ Meetings в†’ Briefs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// A Meeting holds the raw transcript/summary. `extractBrief` (src/lib/ai) turns
// it into a structured brief: the TL;DR lives on the Meeting; decisions,
// feature signals, action items and open questions are normalised child rows so
// they can later link into the Feature Library / Knowledge graph. Re-running the
// extraction clears and re-creates the children (our own data вЂ” safe to delete).

enum MeetingKind {
  INTERNAL
  CUSTOMER
  PROSPECT
}

enum SignalStatus {
  NEW // a feature idea not obviously already built/planned
  ALREADY_TRACKED // sounds like an existing/known capability
  SMALL_UNIQUE // niche, narrow one-off worth keeping
}

model Meeting {
  id           String      @id @default(uuid())
  slug         String      @unique
  title        String
  kind         MeetingKind @default(INTERNAL)
  meetingDate  DateTime
  attendees    String[]    @default([])
  transcript   String // raw pasted transcript / summary
  tldr         String? // AI-generated brief summary
  structuredAt DateTime? // set when the brief was last extracted
  authorId     String
  author       User        @relation(fields: [authorId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt

  decisions      Decision[]
  featureSignals FeatureSignal[]
  actionItems    ActionItem[]
  openQuestions  OpenQuestion[]
  tasks          Task[]          @relation("MeetingTasks")

  @@index([meetingDate])
  @@index([authorId])
  @@map("meeting")
}

model Decision {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  content   String
  owner     String?
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@map("decision")
}

model FeatureSignal {
  id        String       @id @default(uuid())
  meetingId String
  meeting   Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title     String
  detail    String?
  status    SignalStatus @default(NEW)
  tags      String[]     @default([])
  // Set when this signal is promoted into / linked to a Feature Library entry.
  featureId String?
  feature   Feature?     @relation(fields: [featureId], references: [id])
  createdAt DateTime     @default(now())

  @@index([meetingId])
  @@index([status])
  @@index([featureId])
  @@map("feature_signal")
}

model ActionItem {
  id        String    @id @default(uuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  content   String
  assignee  String?
  dueDate   DateTime?
  done      Boolean   @default(false)
  // Set when this action item has been pushed to the task board (1:1).
  taskId    String?   @unique
  task      Task?     @relation(fields: [taskId], references: [id])
  createdAt DateTime  @default(now())

  @@index([meetingId])
  @@map("action_item")
}

model OpenQuestion {
  id        String   @id @default(uuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  content   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@map("open_question")
}

// в”Ђв”Ђв”Ђ Feature Library + Knowledge в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Features are the self-growing catalog. They group into Clusters (the "living
// wiki" hubs) and can cross-link via FeatureLink (the knowledge-graph edges).
// Meeting FeatureSignals promote into Features; RoadmapItems point at Features.

enum FeatureStatus {
  IDEA
  VALIDATED
  IN_ROADMAP
  SHIPPED
  SMALL_UNIQUE
}

enum FeatureLinkKind {
  RELATED
  DEPENDS_ON
}

model Cluster {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  description   String?
  icon          String? // emoji/glyph shown on the hub node
  color         String? // accent token name or hex
  autoSuggested Boolean  @default(false) // emerged from Copilot pattern detection
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  features Feature[]

  @@map("cluster")
}

model Feature {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  description String?
  status      FeatureStatus @default(IDEA)
  tags        String[]      @default([])
  clusterId   String?
  cluster     Cluster?      @relation(fields: [clusterId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  signals      FeatureSignal[] // meeting signals promoted/linked to this feature
  roadmapItems RoadmapItem[]
  linksFrom    FeatureLink[]   @relation("FeatureLinkFrom")
  linksTo      FeatureLink[]   @relation("FeatureLinkTo")

  @@index([clusterId])
  @@index([status])
  @@map("feature")
}

model FeatureLink {
  id        String          @id @default(uuid())
  fromId    String
  toId      String
  kind      FeatureLinkKind @default(RELATED)
  from      Feature         @relation("FeatureLinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        Feature         @relation("FeatureLinkTo", fields: [toId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([fromId, toId])
  @@index([toId])
  @@map("feature_link")
}

// в”Ђв”Ђв”Ђ Roadmap в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Now / Next / Later lanes with sparse `order` for drag autosave (mirror the
// kanban ordering pattern). Items optionally point at a Feature.

enum RoadmapLane {
  NOW
  NEXT
  LATER
}

model RoadmapItem {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  description String?
  lane        RoadmapLane @default(LATER)
  order       Int         @default(0) // sparse ordering within a lane
  confidence  Int         @default(0) // 0-5, shown as the confidence meter
  themeTag    String?
  blocked     Boolean     @default(false)
  blockerNote String?
  featureId   String?
  feature     Feature?    @relation(fields: [featureId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  @@index([lane, order])
  @@map("roadmap_item")
}
