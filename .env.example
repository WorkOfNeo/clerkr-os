# Allowlist of emails that can sign up. Comma-separated, case-insensitive.
ALLOWED_EMAILS=yaw@clerkr.ai,patrick@clerkr.ai,niels@clerkr.ai

# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public base URL for Better Auth (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# Postgres connection URLs.
# - DATABASE_URL: used at runtime. On Railway use the internal URL (no sslmode).
# - DIRECT_URL: used only by `prisma migrate deploy`. For Railway, use the
#   public proxy URL with ?sslmode=require (wiki cmowr1gwc0000pr15wqflwj9s).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clerkr_internal
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/clerkr_internal
