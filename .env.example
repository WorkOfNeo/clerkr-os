# Allowlist of emails that can sign up. Comma-separated, case-insensitive.
ALLOWED_EMAILS=yaw@clerkr.ai,patrick@clerkr.ai,niels@clerkr.ai

# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public base URL for Better Auth (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# Postgres connection URLs. REPLACE THE PLACEHOLDERS BELOW.
# - DATABASE_URL: used at runtime. On Railway use the internal URL (no sslmode).
# - DIRECT_URL: used by `prisma db push` and `prisma migrate deploy`. For
#   Railway, use the public proxy URL with ?sslmode=require
#   (wiki cmowr1gwc0000pr15wqflwj9s).
#
# Railway: in your service Variables tab set:
#   DATABASE_URL = ${{Postgres.DATABASE_PRIVATE_URL}}
#   DIRECT_URL   = ${{Postgres.DATABASE_PUBLIC_URL}}?sslmode=require
# Do NOT paste the literal placeholders below into Railway.
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DB_NAME
DIRECT_URL=postgresql://USER:PASS@HOST:PORT/DB_NAME?sslmode=require
